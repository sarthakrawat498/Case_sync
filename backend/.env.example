# CaseSync Environment Configuration Example
# Copy this file to .env and update with your actual values

# Application Settings
APP_NAME=CaseSync
APP_VERSION=1.0.0
DEBUG=true

# Database - SQLite for easy development (no PostgreSQL setup required)
DATABASE_URL=sqlite:///./casesync.db

# To use PostgreSQL instead, uncomment the line below and update credentials:
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/casesync

# CORS Origins 
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Deepgram API Configuration
# Get your API key from https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_API_URL=https://api.deepgram.com/v1/listen

# NER Model Configuration
NER_MODEL=bert-base-multilingual-cased

# Language Support
SUPPORTED_LANGUAGES=["en", "hi"]
DEFAULT_LANGUAGE=en

# Upload Settings
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes
